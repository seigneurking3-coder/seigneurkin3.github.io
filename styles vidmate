<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VidMate - Vidéo en Streaming</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>VidMate - Streaming Vidéo</h1>
        <p>Recherchez et regardez vos vidéos préférées en streaming !</p>
    </header>

    <!-- Barre de recherche -->
    <section class="search-bar">
        <input type="text" id="search-input" placeholder="Rechercher une vidéo...">
        <button onclick="searchVideo()">Rechercher</button>
    </section>

    <!-- Section des vidéos populaires -->
    <section class="videos">
        <h2>Vidéos Populaires</h2>
        <div class="video-item">
            <iframe width="300" height="200" src="https://www.youtube.com/embed/dQw4w9WgXcQ" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            <p>Titre de la vidéo</p>
        </div>
        <!-- Ajoute d'autres vidéos populaires ici -->
    </section>

    <footer>
        <p>&copy; 2026 VidMate | Tous droits réservés</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
